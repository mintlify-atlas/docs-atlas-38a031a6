  "keyFeatures": [
    "Multi-role authentication system (Admin, Nutritionist, Patient)",
    "Intelligent appointment scheduling with availability management",
    "Clinical attention records with PDF generation",
    "Automated email notifications and reminders",
    "Real-time dashboard with analytics",
    "Nutritionist schedule configuration",
    "Patient medical history tracking",
    "Two-factor authentication with Laravel Fortify",
    "Livewire reactive components with Flux UI",
    "Queue-based notification system"
  ],
  "publicApiSurface": [
    "User::isAdmin() - Check if user has admin role",
    "User::isNutricionista() - Check if user has nutritionist role",
    "User::isPaciente() - Check if user has patient role",
    "User::estaHabilitadoClinicamente() - Check if user is clinically enabled",
    "Appointment::markExpiredAppointments() - Mark expired appointments",
    "Appointment::isExpired() - Check if appointment is expired",
    "AdminController::dashboard() - Admin dashboard view",
    "AdminController::users() - User management",
    "NutricionistaController::schedules() - Schedule management",
    "NutricionistaController::patients() - Patient list for nutritionist",
    "NutricionistaController::appointments() - Appointment management",
    "PacienteController::showBooking() - Patient appointment booking",
    "AttentionController::create() - Create clinical attention record",
    "AttentionPdfController::download() - Generate PDF report",
    "php artisan appointments:send-reminders - Send appointment reminders",
    "AppointmentCreatedNotification - Email notification for new appointments",
    "AppointmentReminderNotification - Email reminder 24h before appointment",
    "WelcomeNotification - Email notification for new users"
  ]
